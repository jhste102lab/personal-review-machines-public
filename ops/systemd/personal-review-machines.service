[Unit]
Description=Personal Review Machines webhook service
After=network-online.target personal-review-machines-chatgpt-browser.service
Wants=network-online.target personal-review-machines-chatgpt-browser.service

[Service]
Type=simple
User=review
Environment=HOME=/home/review
Environment=PATH=/home/review/.local/node/bin:/home/review/.local/bin:/opt/personal-review-machines/scripts:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/snap/bin
Environment=BROWSER_AGENT_HOME=/home/review/.browser-agent
WorkingDirectory=/opt/personal-review-machines
ExecStart=/usr/bin/python3 -m server.app --config /etc/personal-review-machines/config.json
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
