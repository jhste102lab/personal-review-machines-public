#!/usr/bin/env bash
set -euo pipefail

VNC_PORT="${PRM_VNC_PORT:-5901}"
NOVNC_PORT="${PRM_NOVNC_PORT:-6080}"
CDP_PORT="${PRM_CDP_PORT:-9222}"
DISPLAY_NUM="${PRM_DISPLAY:-:99}"

pkill -f "websockify .*${NOVNC_PORT} .*${VNC_PORT}" || true
pkill -f "x11vnc .*${VNC_PORT}" || true
pkill -f "Xvfb ${DISPLAY_NUM}" || true
pkill -f "remote-debugging-port=${CDP_PORT}" || true
