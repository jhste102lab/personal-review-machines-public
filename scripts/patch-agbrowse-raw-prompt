#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--help" ]; then
  cat <<'EOF'
usage: patch-agbrowse-raw-prompt [agbrowse-binary]

Patch the locally installed agbrowse web-ai prompt renderer so commands run with
AGBROWSE_RAW_PROMPT=1 send the exact --prompt text to ChatGPT. Without the env
var, agbrowse behavior is unchanged.
EOF
  exit 0
fi

binary="${1:-}"
if [ -z "$binary" ]; then
  binary="$(command -v agbrowse || true)"
fi
if [ -z "$binary" ] && [ -x "$HOME/.local/node/bin/agbrowse" ]; then
  binary="$HOME/.local/node/bin/agbrowse"
fi
if [ -z "$binary" ]; then
  echo "agbrowse binary not found" >&2
  exit 1
fi

resolved="$(readlink -f "$binary")"
pkg_dir="$(cd "$(dirname "$resolved")/.." && pwd)"
question="$pkg_dir/web-ai/question.mjs"
if [ ! -f "$question" ]; then
  echo "agbrowse question.mjs not found at $question" >&2
  exit 1
fi

python3 - "$question" <<'PY'
from pathlib import Path
import re
import sys
path = Path(sys.argv[1])
text = path.read_text(encoding='utf-8')

helper = """
function renderRawPromptEnvelope(input = {}, contextComposerText = '') {
    if (process.env.AGBROWSE_RAW_PROMPT !== '1') return null;
    const base = String(input.prompt || input.question || '').trim();
    const contextText = String(contextComposerText || '').trim();
    const composerText = contextText ? `${base}\n\n${contextText}` : base;
    return {
        markdown: composerText,
        composerText,
        estimatedChars: composerText.length,
        warnings: ['raw prompt envelope disabled by AGBROWSE_RAW_PROMPT'],
    };
}
"""

if 'function renderRawPromptEnvelope' not in text:
    anchor_re = re.compile(r"(export const CONTENT_BOUNDARY_INSTRUCTIONS = .*?;\n)")
    text, count = anchor_re.subn(r"\1" + helper + "\n", text, count=1)
    if count != 1:
        raise SystemExit('patch anchor not found: CONTENT_BOUNDARY_INSTRUCTIONS')

text, count = re.subn(
    r"export function renderQuestionEnvelope\(input = \{\}\) \{\n"
    r"\s*const envelope = normalizeEnvelope\(input\);\n"
    r"\s*return renderNormalizedEnvelope\(envelope\);\n"
    r"\}",
    "export function renderQuestionEnvelope(input = {}) {\n"
    "    const raw = renderRawPromptEnvelope(input);\n"
    "    if (raw) return raw;\n"
    "    const envelope = normalizeEnvelope(input);\n"
    "    return renderNormalizedEnvelope(envelope);\n"
    "}",
    text,
    count=1,
)
if count != 1 and 'const raw = renderRawPromptEnvelope(input);' not in text:
    raise SystemExit('patch anchor not found: renderQuestionEnvelope')

text, count = re.subn(
    r"export function renderQuestionEnvelopeWithContext\(input = \{\}, contextComposerText = ''\) \{\n"
    r"\s*const envelope = normalizeEnvelope\(input\);",
    "export function renderQuestionEnvelopeWithContext(input = {}, contextComposerText = '') {\n"
    "    const raw = renderRawPromptEnvelope(input, contextComposerText);\n"
    "    if (raw) return raw;\n"
    "    const envelope = normalizeEnvelope(input);",
    text,
    count=1,
)
if count != 1 and 'const raw = renderRawPromptEnvelope(input, contextComposerText);' not in text:
    raise SystemExit('patch anchor not found: renderQuestionEnvelopeWithContext')

backup = path.with_suffix(path.suffix + '.prm-backup')
if not backup.exists():
    backup.write_text(path.read_text(encoding='utf-8'), encoding='utf-8')
path.write_text(text, encoding='utf-8')
print(f'patched {path}')
PY
