#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "--help" ]; then
  cat <<'EOF'
usage: patch-agbrowse-raw-prompt [agbrowse-binary]

Patch the locally installed agbrowse web-ai ChatGPT helpers so:
- AGBROWSE_RAW_PROMPT=1 sends the exact --prompt text to ChatGPT.
- Connector plugins visible in the first composer menu, such as GitHub in the
  current ChatGPT UI, are selected before falling back to the old More submenu.
- The current popover-based ChatGPT menu without role=menuitem is recognized.
Without the env var, normal prompt-envelope behavior is unchanged.
EOF
  exit 0
fi

binary="${1:-}"
if [ -z "$binary" ]; then
  binary="$(command -v agbrowse || true)"
fi
if [ -z "$binary" ] && [ -x "$HOME/.local/node/bin/agbrowse" ]; then
  binary="$HOME/.local/node/bin/agbrowse"
fi
if [ -z "$binary" ]; then
  echo "agbrowse binary not found" >&2
  exit 1
fi

resolved="$(readlink -f "$binary")"
pkg_dir="$(cd "$(dirname "$resolved")/.." && pwd)"
question="$pkg_dir/web-ai/question.mjs"
if [ ! -f "$question" ]; then
  echo "agbrowse question.mjs not found at $question" >&2
  exit 1
fi

python3 - "$question" <<'PY'
from pathlib import Path
import re
import sys
path = Path(sys.argv[1])
text = path.read_text(encoding='utf-8')

helper = """
function renderRawPromptEnvelope(input = {}, contextComposerText = '') {
    if (process.env.AGBROWSE_RAW_PROMPT !== '1') return null;
    const base = String(input.prompt || input.question || '').trim();
    const contextText = String(contextComposerText || '').trim();
    const composerText = contextText ? `${base}\n\n${contextText}` : base;
    return {
        markdown: composerText,
        composerText,
        estimatedChars: composerText.length,
        warnings: ['raw prompt envelope disabled by AGBROWSE_RAW_PROMPT'],
    };
}
"""

if 'function renderRawPromptEnvelope' not in text:
    anchor_re = re.compile(r"(export const CONTENT_BOUNDARY_INSTRUCTIONS = .*?;\n)")
    text, count = anchor_re.subn(r"\1" + helper + "\n", text, count=1)
    if count != 1:
        raise SystemExit('patch anchor not found: CONTENT_BOUNDARY_INSTRUCTIONS')

text, count = re.subn(
    r"export function renderQuestionEnvelope\(input = \{\}\) \{\n"
    r"\s*const envelope = normalizeEnvelope\(input\);\n"
    r"\s*return renderNormalizedEnvelope\(envelope\);\n"
    r"\}",
    "export function renderQuestionEnvelope(input = {}) {\n"
    "    const raw = renderRawPromptEnvelope(input);\n"
    "    if (raw) return raw;\n"
    "    const envelope = normalizeEnvelope(input);\n"
    "    return renderNormalizedEnvelope(envelope);\n"
    "}",
    text,
    count=1,
)
if count != 1 and 'const raw = renderRawPromptEnvelope(input);' not in text:
    raise SystemExit('patch anchor not found: renderQuestionEnvelope')

text, count = re.subn(
    r"export function renderQuestionEnvelopeWithContext\(input = \{\}, contextComposerText = ''\) \{\n"
    r"\s*const envelope = normalizeEnvelope\(input\);",
    "export function renderQuestionEnvelopeWithContext(input = {}, contextComposerText = '') {\n"
    "    const raw = renderRawPromptEnvelope(input, contextComposerText);\n"
    "    if (raw) return raw;\n"
    "    const envelope = normalizeEnvelope(input);",
    text,
    count=1,
)
if count != 1 and 'const raw = renderRawPromptEnvelope(input, contextComposerText);' not in text:
    raise SystemExit('patch anchor not found: renderQuestionEnvelopeWithContext')

backup = path.with_suffix(path.suffix + '.prm-backup')
if not backup.exists():
    backup.write_text(path.read_text(encoding='utf-8'), encoding='utf-8')
path.write_text(text, encoding='utf-8')
print(f'patched {path}')
PY

tools="$pkg_dir/web-ai/chatgpt-tools.mjs"
if [ ! -f "$tools" ]; then
  echo "agbrowse chatgpt-tools.mjs not found at $tools" >&2
  exit 1
fi

python3 - "$tools" <<'PY'
from pathlib import Path
import sys
path = Path(sys.argv[1])
original_text = path.read_text(encoding='utf-8')
text = original_text
text = text.replace(
    "return page.locator('[role=\"menu\"]').evaluateAll((menus) => menus.some(menu => {",
    "return page.locator('[role=\"menu\"], .popover').evaluateAll((menus) => menus.some(menu => {",
)
text = text.replace(
    "return /사진 및 파일 추가|최근 파일|이미지 만들기|심층 리서치|웹 검색|Add photos|Create image|Deep research|Web search/i.test(text);",
    "return /사진 및 파일 추가|최근 파일|이미지 만들기|심층 리서치|웹 검색|Add photos|Create image|Deep research|Web search|GitHub|Supabase|OpenAI Platform/i.test(text);",
)
text = text.replace(
    "const candidates = await page.locator('[role=\"menuitem\"], [role=\"menuitemradio\"], [role=\"menuitemcheckbox\"]').all().catch(() => /** @type {Locator[]} */ ([]));",
    "const candidates = await page.locator('[role=\"menuitem\"], [role=\"menuitemradio\"], [role=\"menuitemcheckbox\"], .popover .__menu-item, .popover [tabindex=\"0\"]').all().catch(() => /** @type {Locator[]} */ ([]));",
)

old = """async function selectMoreComposerMenuItem(page, labels, usedFallbacks) {
    await openComposerPlusMenu(page, usedFallbacks);
    const more = await findVisibleMenuItemByLabels(page, ['더 보기', 'More']);
    if (!more) return false;
    await more.hover({ timeout: 1_000 }).catch(() => undefined);
    await page.waitForTimeout(250).catch(() => undefined);
    if (!(await anyMenuItemVisible(page, labels))) {
        await more.click({ timeout: 2_000 }).catch(() => undefined);
        await page.waitForTimeout(400).catch(() => undefined);
    }
    const item = await findVisibleMenuItemByLabels(page, labels);
    if (!item) return false;
    if (await checkedState(item) === 'true') return true;
    return clickMenuItem(page, item);
}
"""
new = """async function selectMoreComposerMenuItem(page, labels, usedFallbacks) {
    await openComposerPlusMenu(page, usedFallbacks);
    let item = await findVisibleMenuItemByLabels(page, labels);
    if (item) {
        if (await checkedState(item) === 'true') return true;
        return clickMenuItem(page, item);
    }
    const more = await findVisibleMenuItemByLabels(page, ['더 보기', 'More']);
    if (!more) return false;
    await more.hover({ timeout: 1_000 }).catch(() => undefined);
    await page.waitForTimeout(250).catch(() => undefined);
    if (!(await anyMenuItemVisible(page, labels))) {
        await more.click({ timeout: 2_000 }).catch(() => undefined);
        await page.waitForTimeout(400).catch(() => undefined);
    }
    item = await findVisibleMenuItemByLabels(page, labels);
    if (!item) return false;
    if (await checkedState(item) === 'true') return true;
    return clickMenuItem(page, item);
}
"""
if old in text:
    backup = path.with_suffix(path.suffix + '.prm-backup')
    if not backup.exists():
        backup.write_text(path.read_text(encoding='utf-8'), encoding='utf-8')
    path.write_text(text.replace(old, new, 1), encoding='utf-8')
    print(f'patched {path}')
elif 'let item = await findVisibleMenuItemByLabels(page, labels);' in text:
    if text != original_text:
        backup = path.with_suffix(path.suffix + '.prm-backup')
        if not backup.exists():
            backup.write_text(original_text, encoding='utf-8')
        path.write_text(text, encoding='utf-8')
        print(f'patched {path}')
    else:
        print(f'already patched {path}')
else:
    raise SystemExit('patch anchor not found: selectMoreComposerMenuItem')
PY
