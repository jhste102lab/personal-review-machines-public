#!/usr/bin/env bash
set -euo pipefail

DISPLAY_NUM="${PRM_DISPLAY:-:99}"
VNC_PORT="${PRM_VNC_PORT:-5901}"
NOVNC_PORT="${PRM_NOVNC_PORT:-6080}"
CDP_PORT="${PRM_CDP_PORT:-9222}"
EXTRA_CDP_PORTS=""
USER_HOME="${PRM_HOME_OVERRIDE:-$(getent passwd "$(id -un)" | cut -d: -f6)}"
if [ -z "${USER_HOME}" ]; then
  USER_HOME="${HOME:-/tmp}"
fi
BROWSER_AGENT_HOME="${BROWSER_AGENT_HOME:-$USER_HOME/.browser-agent}"
CACHE_DIR="${PRM_CACHE_DIR:-$USER_HOME/.cache/personal-review-machines-chatgpt}"
PROFILE_DIR="${PRM_BROWSER_PROFILE_DIR:-$BROWSER_AGENT_HOME/browser-profile}"
CHATGPT_URL="${PRM_CHATGPT_URL:-https://chatgpt.com/}"
CLOAK_DIR="${PRM_CLOAK_DIR:-$USER_HOME/.local/share/personal-review-machines/cloakbrowser}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export DISPLAY="${DISPLAY_NUM}"

mkdir -p "$CACHE_DIR" "$PROFILE_DIR" "$CLOAK_DIR"

for required in Xvfb x11vnc websockify curl node npm; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "missing required command: $required" >&2
    exit 1
  fi
done

if ! pgrep -f "^Xvfb ${DISPLAY_NUM}( |$)" >/dev/null 2>&1; then
  nohup Xvfb "${DISPLAY_NUM}" -screen 0 1600x1000x24 -ac +extension RANDR > "$CACHE_DIR/xvfb.log" 2>&1 &
  sleep 2
fi

if ! pgrep -f "^x11vnc .* -rfbport ${VNC_PORT}( |$)" >/dev/null 2>&1; then
  nohup x11vnc -display "${DISPLAY_NUM}" -forever -shared -localhost -rfbport "${VNC_PORT}" -nopw > "$CACHE_DIR/x11vnc.log" 2>&1 &
  sleep 2
fi

if ! pgrep -f "^.*websockify .*${NOVNC_PORT} .*${VNC_PORT}" >/dev/null 2>&1; then
  nohup websockify "127.0.0.1:${NOVNC_PORT}" "localhost:${VNC_PORT}" --web=/usr/share/novnc/ > "$CACHE_DIR/websockify.log" 2>&1 &
  sleep 2
fi

for EXTRA_CDP_PORT in $EXTRA_CDP_PORTS; do
  if [ -z "$EXTRA_CDP_PORT" ] || [ "$EXTRA_CDP_PORT" = "$CDP_PORT" ]; then
    continue
  fi
  EXTRA_PROFILE_DIR="$BROWSER_AGENT_HOME/browser-profile-${EXTRA_CDP_PORT}"
  if [ ! -d "$EXTRA_PROFILE_DIR/Default" ]; then
    rm -rf "$EXTRA_PROFILE_DIR"
    cp -a "$PROFILE_DIR" "$EXTRA_PROFILE_DIR"
    rm -f "$EXTRA_PROFILE_DIR"/SingletonCookie "$EXTRA_PROFILE_DIR"/SingletonLock "$EXTRA_PROFILE_DIR"/SingletonSocket
  fi
done

if ! curl -fsS "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1; then
  if ! pgrep -f "remote-debugging-port=${CDP_PORT}" >/dev/null 2>&1; then
    rm -f "$PROFILE_DIR"/SingletonCookie "$PROFILE_DIR"/SingletonLock "$PROFILE_DIR"/SingletonSocket
  fi
  "$SCRIPT_DIR/chatgpt-install-cloak-deps" "$CLOAK_DIR"
  PRM_BROWSER_PROFILE_DIR="$PROFILE_DIR" \
    PRM_CLOAK_DIR="$CLOAK_DIR" \
    PRM_CDP_PORT="$CDP_PORT" \
    PRM_CHATGPT_URL="$CHATGPT_URL" \
    nohup node "$SCRIPT_DIR/chatgpt-cloak-launch.mjs" > "$CACHE_DIR/cloakbrowser.log" 2>&1 &
  sleep 8
fi

for EXTRA_CDP_PORT in $EXTRA_CDP_PORTS; do
  if [ -z "$EXTRA_CDP_PORT" ] || [ "$EXTRA_CDP_PORT" = "$CDP_PORT" ]; then
    continue
  fi
  EXTRA_PROFILE_DIR="$BROWSER_AGENT_HOME/browser-profile-${EXTRA_CDP_PORT}"
  EXTRA_CACHE_LOG="$CACHE_DIR/cloakbrowser-${EXTRA_CDP_PORT}.log"
  if ! curl -fsS "http://127.0.0.1:${EXTRA_CDP_PORT}/json/version" >/dev/null 2>&1; then
    PRM_BROWSER_PROFILE_DIR="$EXTRA_PROFILE_DIR" \
      PRM_CLOAK_DIR="$CLOAK_DIR" \
      PRM_CDP_PORT="$EXTRA_CDP_PORT" \
      PRM_CHATGPT_URL="$CHATGPT_URL" \
      nohup node "$SCRIPT_DIR/chatgpt-cloak-launch.mjs" > "$EXTRA_CACHE_LOG" 2>&1 &
    sleep 8
  fi
done

echo "started"
echo "- CDP: http://127.0.0.1:${CDP_PORT} (CloakBrowser)"
for EXTRA_CDP_PORT in $EXTRA_CDP_PORTS; do
  if [ -n "$EXTRA_CDP_PORT" ] && [ "$EXTRA_CDP_PORT" != "$CDP_PORT" ]; then
    echo "- CDP: http://127.0.0.1:${EXTRA_CDP_PORT} (CloakBrowser)"
  fi
done
echo "- VNC: ssh -L ${VNC_PORT}:127.0.0.1:${VNC_PORT} <host>"
echo "- noVNC: ssh -L ${NOVNC_PORT}:127.0.0.1:${NOVNC_PORT} <host>  then open http://127.0.0.1:${NOVNC_PORT}/vnc.html"
