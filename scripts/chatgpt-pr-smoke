#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ]; then
  echo "usage: chatgpt-pr-smoke <repo> <pr_number> <marker> [reasoning-level]" >&2
  exit 2
fi

REPO="$1"
PR="$2"
MARKER="$3"
REASONING_LEVEL="${4:-Pro}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROMPT_FILE="$(mktemp)"
trap 'rm -f "$PROMPT_FILE"' EXIT

cat > "$PROMPT_FILE" <<PROMPT
PR 번호: #$PR
Git repo: $REPO

이 PR에 테스트 댓글을 직접 작성해.
댓글은 한국어 한두 줄이면 충분하다.
본문 끝에 아래 marker를 그대로 한 줄로 넣어.
$MARKER
PROMPT

"$SCRIPT_DIR/chatgpt-github-review" \
  --url "${PRM_CHATGPT_URL:-https://chatgpt.com/}" \
  --timeout 3600 \
  --prompt-file "$PROMPT_FILE" \
  --reasoning-level "$REASONING_LEVEL" \
  --fallback-delay 30
